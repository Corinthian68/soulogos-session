# Discord bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_bot_token_here

# Path to the Soulogos main memory.sqlite (for player/character lookups)
SOULOGOS_DB_PATH=../soulogos/data/memory.sqlite

# Path where this bot writes its own session.sqlite
SESSION_DB_PATH=data/session.sqlite

# faster-whisper model size: tiny, base, small, medium, large-v2, large-v3
WHISPER_MODEL=base

# Inference device: cpu, cuda, auto
WHISPER_DEVICE=cpu
